# ── 필수 설정 (프로덕션 배포 시 반드시 변경) ────────────────────
# JWT 서명용 시크릿 (openssl rand -hex 32 로 생성 권장)
SECRET_KEY=change-me-to-a-long-random-string

# 허용 도메인 콤마 구분 (와일드카드 "*"는 개발 환경에서만)
CORS_ORIGINS=https://bid.example.com,https://admin.bid.example.com

# ── 공공데이터 API 키 ─────────────────────────────────────────────
# data.go.kr 발급 일반 인증키 (나라장터 입찰공고정보)
# ※ G2B 키 하나로 국방부·군 등 국방 발주 입찰 데이터까지 모두 수집됨
G2B_API_KEY=

# 국방조달(D2B) 별도 호출 활성화 여부 — 기본 false (G2B로 충분)
# 방위사업청 1340000 별도 API를 활용하려면 true + D2B_API_KEY 설정 필요
ENABLE_D2B_SYNC=false
D2B_API_KEY=

# 범용 공공데이터 포털 키 (레거시)
DATA_GO_KR_API_KEY=

# ── 자동 수집 스케줄 ──────────────────────────────────────────────
# hourly / daily / weekly
SYNC_INTERVAL=daily
# HH:MM (daily/weekly일 때 기준 시각, 서버 TZ: Asia/Seoul)
SYNC_TIME=02:00
SYNC_ENABLED=true

# ── 수집 페이지네이션 / 기간 ──────────────────────────────────────
# 1회 호출 당 가져올 행 수 (1~999)
SYNC_ROWS_PER_PAGE=100
# 윈도우당 최대 페이지 수 (공고 / 낙찰)
SYNC_MAX_PAGES_ANN=5
SYNC_MAX_PAGES_RES=5
# data.go.kr API는 7일 초과 inqry 시 빈 응답 → 이 단위로 슬라이딩 윈도우 분할
SYNC_WINDOW_DAYS=7
# 누적 조회 일자 범위 (SYNC_START_DATE 미지정 시 fallback)
SYNC_TOTAL_DAYS_ANN=60
SYNC_TOTAL_DAYS_RES=14
# 전체 백필 시작일 — 지정 시 해당 일자부터 오늘까지 전 구간을 7일 단위로 수집
# 기본값 2019-01-01: 공공데이터 포털 G2B 데이터 가용 기간 시작점
# 카테고리별로 다르게 두려면 SYNC_START_DATE_ANN / SYNC_START_DATE_RES 사용
# 비워두면 SYNC_TOTAL_DAYS_* 의 최근 N일만 수집 (증분 모드)
SYNC_START_DATE=2019-01-01
# SYNC_START_DATE_ANN=2019-01-01
# SYNC_START_DATE_RES=2024-01-01

# 증분 모드 — true 면 직전 성공 수집 시점 - 1일(buffer) 부터만 다시 호출 (cron 비용 절감)
# 최초 1회 backfill 후에는 true 권장. backfill 스크립트는 자동으로 force-full 처리됨.
SYNC_INCREMENTAL=false
SYNC_INCREMENTAL_BUFFER_DAYS=1
# 강제로 전체 구간 재수집하고 싶을 때 true (1회용)
SYNC_FORCE_FULL=false

# ── 데이터 보존 기간 (purge_old_data.py) ─────────────────────────
# 공고/낙찰결과 보관 연수 — 초과분은 주간 cron 으로 삭제 가능
# 사정률 예측 로직 스펙 §3.10 — 10년 이전 데이터 자동 삭제
DATA_RETAIN_YEARS=10
# 수집 로그 보관 일수
SYNC_LOG_RETAIN_DAYS=365

# ── NAS 저장 경로 ────────────────────────────────────────────────
NAS_MOUNT_PATH=/app/data

# ── 로깅 ─────────────────────────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# 로그 파일 경로 (비워두면 stdout만)
LOG_FILE=/app/data/server.log
# 로테이션: 파일당 최대 크기(바이트) × 보관 개수
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=7

# ── uvicorn ──────────────────────────────────────────────────────
# 멀티워커 수
WORKERS=2

# ── 데이터베이스 (PostgreSQL 사용 시) ────────────────────────────
DATABASE_URL=postgresql+asyncpg://biduser:bidpass123@localhost:5432/bid_analysis

# ── 프론트엔드 ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── 운영 알림 (선택) ────────────────────────────────────────────
# Slack/Discord 호환 incoming webhook URL — 수집 실패 시 알림
ALERT_WEBHOOK_URL=
# 누적 수집 실패율 알림 임계치 (0.0~1.0, 기본 0.5)
ALERT_FAILURE_THRESHOLD=0.5
# 임계치 평가 윈도우 (최근 N건, 기본 10)
ALERT_FAILURE_WINDOW=10
# 이메일 알림 (선택, 콤마 구분 다중 가능)
ALERT_EMAIL_TO=
# SMTP 서버 (ALERT_EMAIL_TO 사용 시 필수)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bidstar.local
