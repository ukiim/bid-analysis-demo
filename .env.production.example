# 운영(Production) 환경변수 템플릿
# 사용법:  cp .env.production.example .env  →  필수값 채우기
# ⚠️  절대 .env 파일을 git에 커밋하지 마세요.

# ── 필수 (앱이 시작 시 검증, 미설정/잘못 설정 시 시작 차단) ────
APP_ENV=production
# 32자 이상의 랜덤 문자열. 다음 명령으로 생성:
#   openssl rand -hex 32
SECRET_KEY=__GENERATE_WITH_openssl_rand_hex_32__

# 허용 도메인 (와일드카드 "*" 거부)
# Synology DDNS 사용 예시:
CORS_ORIGINS=https://bid-insight.synology.me
# 자체 도메인 사용 예시 (Cloudflare Tunnel):
# CORS_ORIGINS=https://bid.example.com
# 두 도메인 동시 운영 시 콤마 구분:
# CORS_ORIGINS=https://bid-insight.synology.me,https://bid.example.com

# ── 공공데이터 API ──────────────────────────────────────────
# data.go.kr 발급 일반 인증키 (88자, Base64). G2B 키 하나로 국방부 데이터 포함
G2B_API_KEY=

# D2B 별도 호출 (기본 false — G2B로 충분)
ENABLE_D2B_SYNC=false
D2B_API_KEY=

# ── 자동 수집 스케줄 ────────────────────────────────────────
SYNC_INTERVAL=daily
SYNC_TIME=02:00
SYNC_ENABLED=true

# 페이지네이션 / 슬라이딩 윈도우
SYNC_ROWS_PER_PAGE=100
SYNC_MAX_PAGES_ANN=5
SYNC_MAX_PAGES_RES=5
SYNC_WINDOW_DAYS=7
SYNC_TOTAL_DAYS_ANN=60
SYNC_TOTAL_DAYS_RES=14

# ── 로깅 ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=/app/data/server.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=7

# ── 분석 캐시 ───────────────────────────────────────────────
ANALYSIS_CACHE_SIZE=256
ANALYSIS_CACHE_TTL=300

# ── uvicorn 워커 ────────────────────────────────────────────
# CPU 코어 수에 따라 조정 (보통 코어수 × 2)
WORKERS=2

# ── 외부 노출 모드 ─────────────────────────────────────────
# Synology DDNS + 역방향 프록시 모드: 0.0.0.0 (기본) — DSM 역방향 프록시에서 접근
# Cloudflare Tunnel 모드: 127.0.0.1 — 외부 직접 노출 차단, cloudflared만 접근
BACKEND_BIND=0.0.0.0

# ── Cloudflare Tunnel (옵션 B, Synology DDNS 미사용 시) ────
# Cloudflare Zero Trust → Tunnels에서 발급받은 토큰
CLOUDFLARE_TUNNEL_TOKEN=

# ── 관리자 초기 계정 (init_admin.py 자동 실행 시) ──────────
# 1회용 환경변수, 첫 부팅 후 .env에서 제거 권장
INIT_ADMIN_EMAIL=
INIT_ADMIN_PASSWORD=
INIT_ADMIN_NAME=운영 관리자
